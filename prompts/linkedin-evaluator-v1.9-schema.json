    "referral_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "linkedin_url": {"anyOf": [{"type": "string"}, {"type": "null"}]},
          "current_title": {"anyOf": [{"type": "string"}, {"type": "null"}]},
          "current_company": {"anyOf": [{"type": "string"}, {"type": "null"}]},
          "location": {"anyOf": [{"type": "string"}, {"type": "null"}]},
          "estimated_miles_to_fort_lee": {"anyOf": [{"type": "number"}, {"type": "null"}]},
          "has_flutter_experience": {"anyOf": [{"type": "boolean"}, {"type": "null"}]},
          "has_mobile_experience": {"anyOf": [{"type": "boolean"}, {"type": "null"}]},
          "is_contractor": {"anyOf": [{"type": "boolean"}, {"type": "null"}]},
          "referral_confidence": {"anyOf": [{"type": "string"}, {"type": "null"}]},
          "referral_notes": {"anyOf": [{"type": "string"}, {"type": "null"}]},
          "source": {"anyOf": [{"type": "string"}, {"type": "null"}]}
        },
        "required": ["name", "linkedin_url", "referral_confidence"]
      }
    }
